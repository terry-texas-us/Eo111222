---
Checks:            '-*,readability-identifier-naming,modernize-use-auto'
ExtraArgs:
  - '-I"C:/Program Files/LLVM/lib/clang/21/include"'
CheckOptions:
  # Core variable styles – camelBack = camelCase (starts lowercase)
  - { key: readability-identifier-naming.LocalVariableCase,     value: camelBack }   # e.g., myLocalVar
  # - { key: readability-identifier-naming.ParameterCase,         value: camelBack }   # e.g., myParam
  # - { key: readability-identifier-naming.ClassMemberCase,     value: camelBack }   # e.g., myMember (non-private)
  # - { key: readability-identifier-naming.PrivateMemberCase,     value: camelBack }   # private members
  # - { key: readability-identifier-naming.PrivateMemberPrefix,   value: m_ }          # optional: m_myPrivateMember

  # - { key: readability-identifier-naming.GlobalVariableCase,  value: camelBack }
  # - { key: readability-identifier-naming.StaticVariableCase,  value: camelBack }
  # - { key: readability-identifier-naming.ConstantCase,        value: UPPER_CASE }  # e.g., MY_CONST
  # - { key: readability-identifier-naming.MemberCase,          value: camelBack }   # generic fallback
WarningsAsErrors:  ''
HeaderFilterRegex: 'D:/Projects/Eo111222/Application/AeSys/.*'
FormatStyle:       'file'
User:              tsmit